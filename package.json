{
  "name": "changelog-analyze-action",
  "version": "1.0.0",
  "description": "GitHub Action that uses LLMs to produce executive-friendly insights from changeset data",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --sourcemap",
    "build:check": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "github-action",
    "changelog",
    "llm",
    "ai",
    "fireworks",
    "openai",
    "anthropic",
    "ollama"
  ],
  "author": "marco-jardim",
  "license": "GPL-3.0",
  "dependencies": {
    "@actions/core": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
